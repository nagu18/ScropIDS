DJANGO_SECRET_KEY=replace-me
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

POSTGRES_DB=scropids
POSTGRES_USER=scropids
POSTGRES_PASSWORD=scropids
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
USE_SQLITE=True

REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Any random string works; it is internally transformed into a valid Fernet key.
SCROPIDS_ENCRYPTION_KEY=replace-with-strong-passphrase

# Frontend origin(s) for CORS if enabled later
FRONTEND_ORIGIN=http://localhost:5173

# Optional alert channels
ALERT_EMAIL_FROM=scropids@localhost
ALERT_EMAIL_TO=
SLACK_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
